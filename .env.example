# MQTT Broker WebSocket URL
# For HiveMQ Cloud: wss://YOUR-CLUSTER.s1.eu.hivemq.cloud:8884/mqtt
# For public broker (testing only): wss://broker.hivemq.com:8884/mqtt
NEXT_PUBLIC_MQTT_BROKER=wss://broker.hivemq.com:8884/mqtt

# Security Validation Options (Requires matching backend logic if applicable)
NEXT_PUBLIC_ACCESS_CODE=circuit
NEXT_PUBLIC_SECURITY_PIN=1234
NEXT_PUBLIC_REACTIVATE_CODE=CBMA
